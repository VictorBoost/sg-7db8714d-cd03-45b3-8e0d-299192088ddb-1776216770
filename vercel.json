{
  "version": 2,
  "public": true,
  "alias": ["bluetika.co.nz", "www.bluetika.co.nz"],
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/old-path",
      "destination": "/new-path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/escrow/auto-release-pipeline",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/escrow/friday-payout",
      "schedule": "0 20 * * 4"
    }
  ]
}